{
  "expo": {
    "name": "callkittiFE",
    "slug": "callkittiFE",
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./assets/images/icon.png",
    "scheme": "callkittife",
    "userInterfaceStyle": "automatic",
  
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
     
      },
     
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.callkittiFE"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
